generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Obra {
  id         String    @id @default(cuid())
  nome       String
  cliente    String
  endereco   String?
  cidade     String?
  dataInicio DateTime
  dataFim    DateTime?
  status     String    @default("em_andamento")
  orcamento  Float
  descricao  String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  lancamentos       Lancamento[]
  pagamentos        Pagamento[]
  funcionariosObra  FuncionarioObra[]
  solicitacoes      SolicitacaoAdiantamento[]
  fotosRecibo       FotoRecibo[]
  fotosObra         FotoObra[]
  pontos            RegistroPonto[]
  movOrigem         MovimentacaoMaterial[] @relation("MovOrigem")
  movDestino        MovimentacaoMaterial[] @relation("MovDestino")
}

model Funcionario {
  id          String   @id @default(cuid())
  nome        String
  cpf         String?  @unique
  cargo       String
  salarioBase Float
  valorHora   Float?
  fotoCaminho String?
  status      String   @default("ativo")
  telefone    String?
  email       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pagamentos       Pagamento[]
  funcionariosObra FuncionarioObra[]
  solicitacoes     SolicitacaoAdiantamento[]
  pontos           RegistroPonto[]
}

model FuncionarioObra {
  id            String    @id @default(cuid())
  funcionarioId String
  obraId        String
  dataInicio    DateTime
  dataFim       DateTime?
  funcao        String?
  createdAt     DateTime  @default(now())

  funcionario Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  obra        Obra        @relation(fields: [obraId], references: [id], onDelete: Cascade)

  @@unique([funcionarioId, obraId])
}

model Lancamento {
  id        String   @id @default(cuid())
  obraId    String
  tipo      String
  valor     Float
  descricao String
  categoria String
  data      DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  obra Obra @relation(fields: [obraId], references: [id], onDelete: Cascade)
}

model Pagamento {
  id            String   @id @default(cuid())
  funcionarioId String
  obraId        String
  valor         Float
  tipo          String
  data          DateTime
  descricao     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  funcionario Funcionario @relation(fields: [funcionarioId], references: [id], onDelete: Cascade)
  obra        Obra        @relation(fields: [obraId], references: [id], onDelete: Cascade)
}

// ─── Auth & Usuários ──────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  name         String
  passwordHash String
  status       String   @default("ativo")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  grupos                UserGrupo[]
  solicitacoesCriadas   SolicitacaoAdiantamento[] @relation("SolicitacaoCriador")
  solicitacoesAprovadas SolicitacaoAdiantamento[] @relation("SolicitacaoAprovador")
  fotosRecibo           FotoRecibo[]
  fotosObra             FotoObra[]
  pontosRegistrados     RegistroPonto[]
  movimentacoes         MovimentacaoMaterial[]
}

model Grupo {
  id        String   @id @default(cuid())
  nome      String   @unique
  createdAt DateTime @default(now())

  usuarios UserGrupo[]
}

model UserGrupo {
  userId  String
  grupoId String

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  grupo Grupo @relation(fields: [grupoId], references: [id], onDelete: Cascade)

  @@id([userId, grupoId])
}

// ─── Workflow Adiantamentos ───────────────────────────────────────────────────

model SolicitacaoAdiantamento {
  id              String    @id @default(cuid())
  funcionarioId   String
  obraId          String
  valor           Float
  motivo          String
  status          String    @default("pendente")
  valorAutorizado Float?
  motivoResposta  String?
  criadoPorId     String
  aprovadoPorId   String?
  criadoEm        DateTime  @default(now())
  respondidoEm    DateTime?
  updatedAt       DateTime  @updatedAt

  funcionario Funcionario @relation(fields: [funcionarioId], references: [id])
  obra        Obra        @relation(fields: [obraId], references: [id])
  criadoPor   User        @relation("SolicitacaoCriador", fields: [criadoPorId], references: [id])
  aprovadoPor User?       @relation("SolicitacaoAprovador", fields: [aprovadoPorId], references: [id])
}

// ─── Fotos de Recibos (OCR) ───────────────────────────────────────────────────

model FotoRecibo {
  id                String   @id @default(cuid())
  userId            String
  obraId            String?
  imagemBase64      String?
  textoOCR          String?
  dadosEstruturados String?
  status            String   @default("processando")
  createdAt         DateTime @default(now())

  user User  @relation(fields: [userId], references: [id])
  obra Obra? @relation(fields: [obraId], references: [id])
}

// ─── Fotos da Obra ────────────────────────────────────────────────────────────

model FotoObra {
  id           String   @id @default(cuid())
  obraId       String
  userId       String
  imagemPath   String   // URL relativa: /uploads/obras/[obraId]/[filename]
  descricao    String?
  dataRegistro DateTime
  createdAt    DateTime @default(now())

  obra Obra @relation(fields: [obraId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
}

// ─── Registro de Ponto ────────────────────────────────────────────────────────

model RegistroPonto {
  id              String   @id @default(cuid())
  funcionarioId   String
  obraId          String?
  tipo            String   // entrada | saida
  dataHora        DateTime
  registradoPorId String
  observacao      String?
  status          String   @default("em_aberto")
  createdAt       DateTime @default(now())

  funcionario   Funcionario @relation(fields: [funcionarioId], references: [id])
  obra          Obra?       @relation(fields: [obraId], references: [id])
  registradoPor User        @relation(fields: [registradoPorId], references: [id])
}

// ─── Controle de Material ─────────────────────────────────────────────────────

model Material {
  id              String   @id @default(cuid())
  nome            String
  descricao       String?
  codigo          String?  @unique
  categoria       String?
  unidade         String   @default("un")
  quantidadeTotal Int      @default(1)
  fotoCaminho     String?
  status          String   @default("ativo")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  movimentacoes MovimentacaoMaterial[]
}

model MovimentacaoMaterial {
  id              String   @id @default(cuid())
  materialId      String
  obraOrigemId    String?  // null = depósito
  obraDestinoId   String?  // null = depósito
  quantidade      Int      @default(1)
  data            DateTime
  observacao      String?
  registradoPorId String
  createdAt       DateTime @default(now())

  material      Material @relation(fields: [materialId], references: [id])
  obraOrigem    Obra?    @relation("MovOrigem", fields: [obraOrigemId], references: [id])
  obraDestino   Obra?    @relation("MovDestino", fields: [obraDestinoId], references: [id])
  registradoPor User     @relation(fields: [registradoPorId], references: [id])
}
